# PostgreSQL bağlantı adresi (Docker)
# docker run -d --name ecocampus-db -e POSTGRES_PASSWORD=postgres -e POSTGRES_DB=ecocampus -p 5432:5432 postgres:16
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ecocampus

# JWT imzalama anahtarı (mutlaka güçlü ve gizli bir değerle değiştirin)
JWT_SECRET=your_jwt_secret_here

# Sunucu portu
PORT=5000

# CORS - izin verilen origin'ler (virgülle ayrılmış)
CORS_ORIGIN=http://localhost:5173

# Genel API rate limit (tüm uçlar için)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300

# Auth uçları (login/register) için daha sıkı rate limit
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=10
